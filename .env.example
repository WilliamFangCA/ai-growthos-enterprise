# ── Primary AI (GLM-5-turbo via Z.ai Anthropic-format endpoint) ──────────────
GLM_API_KEY=your_glm_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic/v1

# ── Fallback AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_claude_key_here
MINIMAX_API_KEY=your_minimax_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
OLLAMA_BASE_URL=http://localhost:11434

# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
AUTO_COMPANY_PATH=../..

# ── Cloudflare Deployment ─────────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Required scopes: Edit Cloudflare Workers, Edit Cloudflare Pages, Edit D1
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# ── App secret（憑證加密金鑰）──────────────────────────────────────────────────
# 用於將平台 access_token/secret 加密後存入 DB。請設一組 32+ 字元隨機字串。
# 未設定時退回開發用派生金鑰（不安全，正式環境務必設定）。
APP_SECRET=please_set_a_long_random_string_32chars_min

# 對外公開網址（webhook / 金流回調 / OAuth callback 用，需 HTTPS 可達）
# 例：https://ai-growthos-enterprise-production.up.railway.app；留空則自動由請求推斷
APP_BASE_URL=

# ── Messaging Platforms ───────────────────────────────────────────────────────
# 注意：通訊帳號憑證建議改用 App 內「設定 → 通訊軟體 → 真實連接」填入（加密存 DB + 線上驗證）。
# 下列 env 為選用備援；META_* 為 Meta（Messenger/IG/WhatsApp）webhook 共用設定。
LINE_CHANNEL_ACCESS_TOKEN=your_line_token
LINE_CHANNEL_SECRET=your_line_secret
TELEGRAM_BOT_TOKEN=your_telegram_token
WHATSAPP_TOKEN=your_whatsapp_token
META_APP_SECRET=your_meta_app_secret
META_VERIFY_TOKEN=your_meta_webhook_verify_token

# ── 藍新金流 NewebPay（MPG 幕前支付）──────────────────────────────────────────
# 商店後台取得：https://www.newebpay.com → 商店設定 → 金鑰管理
# HASH_KEY 為 32 字元、HASH_IV 為 16 字元
NEWEBPAY_MERCHANT_ID=your_newebpay_merchant_id
NEWEBPAY_HASH_KEY=your_newebpay_hash_key_32chars
NEWEBPAY_HASH_IV=your_hash_iv_16c
NEWEBPAY_ENV=test          # test | production

# ── Shopee Open Platform（電商真實串接範本）──────────────────────────────────
# 取得：https://open.shopee.com → App 管理
SHOPEE_PARTNER_ID=your_shopee_partner_id
SHOPEE_PARTNER_KEY=your_shopee_partner_key
SHOPEE_ENV=test            # test | production

# ── Primary AI (GLM-5-turbo via Z.ai Anthropic-format endpoint) ──────────────
GLM_API_KEY=your_glm_key_here
GLM_BASE_URL=https://open.bigmodel.cn/api/anthropic/v1

# ── Fallback AI ───────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_claude_key_here
MINIMAX_API_KEY=your_minimax_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
OLLAMA_BASE_URL=http://localhost:11434

# ── App ───────────────────────────────────────────────────────────────────────
PORT=4000
NODE_ENV=development
AUTO_COMPANY_PATH=../..

# ── Cloudflare Deployment ─────────────────────────────────────────────────────
# Get from: https://dash.cloudflare.com/profile/api-tokens
# Required scopes: Edit Cloudflare Workers, Edit Cloudflare Pages, Edit D1
CLOUDFLARE_API_TOKEN=your_cloudflare_api_token
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id

# ── Messaging Platforms (optional) ────────────────────────────────────────────
LINE_CHANNEL_ACCESS_TOKEN=your_line_token
LINE_CHANNEL_SECRET=your_line_secret
TELEGRAM_BOT_TOKEN=your_telegram_token
WHATSAPP_TOKEN=your_whatsapp_token
